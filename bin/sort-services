#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use App\Command\CheckCommand;
use App\Command\FixCommand;
use App\IO\NativeFileIO;
use App\Parser\YamlServiceParser;
use App\Sorter\ServiceKeyNormalizer;
use App\Sorter\ServiceKeySorter;
use App\Sorter\ServiceOrderChecker;
use App\Sorter\ServicesSorter;
use Symfony\Component\Console\Application;

$parser = new YamlServiceParser();
$keySorter = new ServiceKeySorter(new ServiceKeyNormalizer());

$application = new Application('sort-services', '1.0.0');
$application->addCommand(new CheckCommand($parser, new ServiceOrderChecker($keySorter), new NativeFileIO()));
$application->addCommand(new FixCommand($parser, new ServicesSorter($keySorter, new ServiceKeyNormalizer()), new NativeFileIO()));
$application->run();
