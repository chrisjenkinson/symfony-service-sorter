{
    "name": "chrisjenkinson/symfony-service-sorter",
    "description": "Sorts entries in the services: key of Symfony YAML files alphabetically",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "keywords": ["symfony", "yaml", "services", "sort", "cli"],
    "authors": [
        {
            "name": "Chris Jenkinson",
            "homepage": "https://github.com/chrisjenkinson"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/console": "^6.0 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "infection/infection": "^0.33",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^13",
        "symplify/easy-coding-standard": "^13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/sort-services"],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "prefer-stable": true,
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "minimum-stability": "stable"
}
